# packages/workstation.list — Desktop environment packages

# Sway + Wayland
sway
swaylock
swayidle
xdg-desktop-portal-wlr
xorg-xwayland

# Bar
waybar

# Wallpaper
swaybg

# Launcher
wofi

# Terminal
ghostty

# File manager (TUI)
yazi

# Notifications
mako
libnotify

# Screenshot / clipboard
grim
slurp
wl-clipboard

# Qt Wayland support (native rendering instead of XWayland fallback)
qt5-wayland
qt6-wayland

# Brightness / display control (both harmless when unused)
brightnessctl
ddcutil

# Authentication agent (needed for privilege escalation prompts in Sway)
polkit-gnome

# Network Manager tray icon (WiFi GUI in Sway)
network-manager-applet

# Bluetooth
bluez
bluez-utils

# Theming
adwaita-icon-theme
papirus-icon-theme
breeze-gtk
qt6ct
kvantum
kvantum-qt5

# Tray icon support (needed for Chrome, JB Toolbox, Dropbox, etc.)
libappindicator-gtk3

# WebKit rendering engine (4.0 for GTK apps, 4.1 for Tauri v2 apps)
webkit2gtk
webkit2gtk-4.1

# Blue light filter (Wayland-native, minimal)
wlsunset

# Clipboard history (Wayland-native, pairs with wl-clipboard)
cliphist

# Desktop applications
obsidian
keepassxc
obs-studio
gimp
libreoffice-fresh

# Code editor
code

# VPN
wireguard-tools

# Git + GitHub
openssh
github-cli
sshpass

# Communication
telegram-desktop
discord
